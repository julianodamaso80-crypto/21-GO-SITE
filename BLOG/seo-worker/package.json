{
  "name": "seo-worker",
  "version": "0.1.0",
  "description": "Operacao SEO/blog automatizada da 21Go — orquestrador de 15 agentes (DataForSEO + GSC + GA4 + Bing + IndexNow + Supabase + GitHub).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo '(lint nao configurado ainda)'",
    "test:connect": "tsx src/scripts/test-connect.ts",
    "test:dry-draft": "tsx src/scripts/test-dry-draft.ts",
    "google:auth": "tsx src/scripts/google-auth.ts"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@supabase/supabase-js": "^2.105.1",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.177",
    "axios": "^1.16.0",
    "bullmq": "^5.28.1",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "undici": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
