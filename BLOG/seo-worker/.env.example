# =============================================================================
# seo-worker — variaveis de ambiente
# Copiar para .env (gitignored) ou configurar no EasyPanel (servico seo-worker).
# NAO commitar valores reais.
# =============================================================================

# ----- Runtime -----
NODE_ENV=production
PORT=8080
LOG_LEVEL=info               # debug | info | warn | error
COMPANY_ID=company-21go      # fixo — multi-tenant filtra por isso

# ----- Supabase (super-banco da 21Go) -----
SUPABASE_URL=                # ex: https://dsclaxtvcbbuxmtmpxpf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ----- Redis (BullMQ + cache) -----
# No EasyPanel, dentro da rede do projeto social-21go, hostname e redis-social.
REDIS_URL=redis://redis-social:6379

# ----- Anthropic (Claude) -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_MAIN=        # ex: claude-sonnet-4-6 (modelo principal — Writer/Reviewer/Strategist/Briefing/Analyst)
ANTHROPIC_MODEL_LIGHT=       # ex: claude-haiku-4-5-20251001 (agentes leves — Repurpose/classificacoes)

# ----- DataForSEO -----
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_DAILY_BUDGET_USD=2

# ----- Google Search Console + GA4 -----
# Opcao 1: OAuth refresh token (mais simples para conta pessoal)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GSC_SITE_URL=https://21go.site/

# Opcao 2: Service Account JSON (recomendado para producao)
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=   # JSON inteiro, em UMA linha (escapar quebras)

# ----- Bing + IndexNow -----
BING_API_KEY=
BING_SITE_URL=https://21go.site/
INDEXNOW_KEY=                # UUID v4 (gerar e servir em /{key}.txt no site publico)
INDEXNOW_KEY_LOCATION=https://21go.site/{key}.txt

# ----- GitHub (Publisher commita MDX) -----
GITHUB_TOKEN=                # PAT fine-grained: Contents=write + Pull requests=write no repo
GITHUB_REPO=julianodamaso80-crypto/21-GO-SITE   # owner/repo
GITHUB_BRANCH_BASE=master    # branch onde o MDX vai (EasyPanel deploya disso)
GITHUB_AUTHOR_NAME=21Go SEO Bot
GITHUB_AUTHOR_EMAIL=seo-bot@21go.site

# ----- Seguranca de webhooks -----
TRIGGER_SECRET=              # bearer obrigatorio em POST /runs/* e /webhooks/*

# ----- Comportamento -----
AUTO_PUBLISH_ENABLED=false   # NUNCA true nos primeiros 30 dias
DAILY_ARTICLE_LIMIT=1        # quantos rascunhos criar por dia
WEEKLY_KEYWORD_LIMIT=20      # quantas keywords novas pesquisar por semana
WORDS_PER_ARTICLE_MIN=900    # minimo aceito pelo OnPage
WORDS_PER_ARTICLE_MAX=2200   # maximo recomendado

# ----- Timezone do cron -----
TZ=America/Sao_Paulo
