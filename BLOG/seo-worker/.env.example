# =============================================================================
# seo-worker — variaveis de ambiente
# Copiar para .env (gitignored) ou configurar no EasyPanel (servico seo-worker).
# NAO commitar valores reais.
#
# A maioria dessas envs JA EXISTE no .env raiz do projeto e em
# 21go-website/.env.local — reaproveite no EasyPanel.
# =============================================================================

# ----- Runtime -----
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
COMPANY_ID=company-21go
TZ=America/Sao_Paulo

# ----- Supabase (super-banco da 21Go) -----
SUPABASE_URL=                # ex: https://dsclaxtvcbbuxmtmpxpf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ----- Redis (BullMQ + cache) -----
# No EasyPanel, dentro da rede do projeto social-21go, hostname e redis-social.
REDIS_URL=redis://redis-social:6379

# ----- LLM via OpenRouter (mesmo provider do agente Leticya) -----
# Modelos reusam a convencao AI_MODEL_* JA existente no .env do projeto.
# Sem env, usa fallbacks documentados em src/config.ts (com log.warn).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=          # opcional — sem isso usa default do SDK

# Slugs OpenRouter (formato "provider/modelo")
AI_MODEL_GENERATOR=anthropic/claude-sonnet-4.6   # tier MAIN — Writer/Reviewer/Strategist/Briefing/Updater
AI_MODEL_CLASSIFIER=anthropic/claude-haiku-4.5    # tier LIGHT — Repurpose, judge, classificacoes

# ----- DataForSEO -----
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_DAILY_BUDGET_USD=2

# ----- Google OAuth (GSC + GA4) -----
# Gere GOOGLE_REFRESH_TOKEN com: `npm run google:auth`
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GSC_SITE_URL=https://21go.site/
GA4_PROPERTY_ID=              # numerico (ex: 123456789), diferente do GA4_MEASUREMENT_ID

# ----- Bing + IndexNow -----
BING_API_KEY=
BING_SITE_URL=https://21go.site/
INDEXNOW_KEY=                 # UUID v4 (servir em /{key}.txt no site publico)
INDEXNOW_KEY_LOCATION=https://21go.site/{key}.txt

# ----- GitHub (Publisher abre Pull Request — SEM auto-merge na master) -----
GITHUB_TOKEN=                 # PAT fine-grained: Contents=write + Pull requests=write
GITHUB_REPO=julianodamaso80-crypto/21-GO-SITE   # owner/repo (ja com default no config)
GITHUB_BRANCH_BASE=master     # branch alvo do PR
GITHUB_AUTHOR_NAME=21Go SEO Bot
GITHUB_AUTHOR_EMAIL=seo-bot@21go.site

# ----- Seguranca de webhooks -----
TRIGGER_SECRET=               # bearer obrigatorio em POST /runs/* e /webhooks/*

# ----- Comportamento -----
AUTO_PUBLISH_ENABLED=false    # NUNCA true nos primeiros 30 dias
DAILY_ARTICLE_LIMIT=1
WEEKLY_KEYWORD_LIMIT=20
WORDS_PER_ARTICLE_MIN=900
WORDS_PER_ARTICLE_MAX=2200
